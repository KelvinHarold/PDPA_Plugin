<div class="local-privacy-portal">
    <div class="row">
        <!-- Consent Management Section -->
        <div class="col-md-6">
            <div class="card mb-4 shadow-sm border-0">
                <div class="card-header bg-primary text-white d-flex align-items-center">
                    <i class="fa fa-shield fa-lg mr-2"></i>
                    <h5 class="mb-0">{{#str}}consent_management, local_privacy_portal{{/str}}</h5>
                </div>
                <div class="card-body">
                    <form action="{{save_url}}" method="post">
                        <input type="hidden" name="sesskey" value="{{sesskey}}">
                        <input type="hidden" name="action" value="saveconsent">
                        
                        {{#consent}}
                        <div class="consent-item d-flex justify-content-between align-items-start border-bottom py-3">
                            <div class="flex-grow-1">
                                <label class="h6 mb-1 d-block" for="id_{{name}}">{{label}}</label>
                                <p class="text-muted small mb-2">{{desc}}</p>
                                <span class="badge {{badge_class}}">{{status_label}}</span>
                            </div>
                            <div class="custom-control custom-switch mt-1">
                                <input type="checkbox" class="custom-control-input" id="id_{{name}}" name="{{name}}" value="1" {{checked}}>
                                <label class="custom-control-label" for="id_{{name}}"></label>
                            </div>
                        </div>
                        {{/consent}}
                        
                        <div class="mt-4 text-right">
                            <button type="submit" class="btn btn-primary px-4 shadow-sm">
                                <i class="fa fa-save mr-1"></i> {{#str}}save_changes, local_privacy_portal{{/str}}
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Data Portability Section -->
        <div class="col-md-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-info text-white d-flex align-items-center">
                    <i class="fa fa-download fa-lg mr-2"></i>
                    <h5 class="mb-0">{{#str}}data_portability, local_privacy_portal{{/str}}</h5>
                </div>
                <div class="card-body">
                    <form action="{{export_url}}" method="post" target="_blank">
                        <input type="hidden" name="sesskey" value="{{sesskey}}">
                        <input type="hidden" name="id" value="{{userid}}">
                        
                        <p class="font-weight-bold mb-3">{{#str}}select_data_categories, local_privacy_portal{{/str}}</p>
                        
                        <div class="custom-control custom-checkbox mb-2">
                            <input type="checkbox" class="custom-control-input" id="cat_profile" name="categories[]" value="profile" checked>
                            <label class="custom-control-label" for="cat_profile">{{#str}}cat_profile, local_privacy_portal{{/str}}</label>
                        </div>
                        <div class="custom-control custom-checkbox mb-2">
                            <input type="checkbox" class="custom-control-input" id="cat_grades" name="categories[]" value="grades" checked>
                            <label class="custom-control-label" for="cat_grades">{{#str}}cat_grades, local_privacy_portal{{/str}}</label>
                        </div>
                        <div class="custom-control custom-checkbox mb-4">
                            <input type="checkbox" class="custom-control-input" id="cat_activity" name="categories[]" value="activity">
                            <label class="custom-control-label" for="cat_activity">{{#str}}cat_activity, local_privacy_portal{{/str}}</label>
                        </div>
                        
                        <div class="form-group mb-4">
                            <label for="id_format" class="font-weight-bold">{{#str}}export_format, local_privacy_portal{{/str}}</label>
                            <select name="format" id="id_format" class="form-control custom-select">
                                <option value="json">JSON (Data Interchange)</option>
                                <option value="csv">CSV (Spreadsheet/Excel)</option>
                            </select>
                        </div>
                        
                        <button type="submit" class="btn btn-info btn-block shadow-sm">
                            <i class="fa fa-file-download mr-1"></i> {{#str}}download_btn, local_privacy_portal{{/str}}
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Third Party Sharing Notifications -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white d-flex align-items-center">
                    <i class="fa fa-exchange fa-lg mr-2"></i>
                    <h5 class="mb-0">Third-party Sharing Notifications</h5>
                </div>
                <div class="card-body">
                    {{#has_sharing}}
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Third Party</th>
                                    <th>Purpose</th>
                                    <th>Data Categories</th>
                                    <th>Date Shared</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#sharing_history}}
                                <tr>
                                    <td><strong>{{thirdpartyname}}</strong></td>
                                    <td>{{purpose}}</td>
                                    <td><span class="badge badge-light">{{categories}}</span></td>
                                    <td>{{date}}</td>
                                </tr>
                                {{/sharing_history}}
                            </tbody>
                        </table>
                    </div>
                    {{/has_sharing}}
                    {{^has_sharing}}
                    <div class="text-center py-4 text-muted">
                        <i class="fa fa-info-circle fa-2x mb-2"></i>
                        <p>No recent third-party sharing events recorded.</p>
                    </div>
                    {{/has_sharing}}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.local-privacy-portal .card {
    border-radius: 12px;
    overflow: hidden;
}
.local-privacy-portal .card-header {
    padding: 1.25rem;
}
.local-privacy-portal .consent-item:last-child {
    border-bottom: 0 !important;
}
.local-privacy-portal .custom-switch .custom-control-label::before {
    height: 1.5rem;
    width: 2.75rem;
    border-radius: 1rem;
}
.local-privacy-portal .custom-switch .custom-control-label::after {
    width: calc(1.5rem - 4px);
    height: calc(1.5rem - 4px);
    background-color: #adb5bd;
    border-radius: 50%;
}
.local-privacy-portal .custom-control-input:checked ~ .custom-control-label::after {
    background-color: #fff;
    transform: translateX(1.25rem);
}
</style>
