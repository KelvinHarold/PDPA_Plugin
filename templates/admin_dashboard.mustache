<div class="pdpa-dashboard">
    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card bg-primary text-white shadow-sm border-0 text-center p-3">
                <h2 class="mb-0">{{total_users}}</h2>
                <p class="mb-0">Total Users</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success text-white shadow-sm border-0 text-center p-3">
                <h2 class="mb-0">{{sharing_count}}</h2>
                <p class="mb-0">Sharing Consents</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info text-white shadow-sm border-0 text-center p-3">
                <h2 class="mb-0">{{total_requests}}</h2>
                <p class="mb-0">Data Requests</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning text-white shadow-sm border-0 text-center p-3">
                <h2 class="mb-0">{{marketing_count}}</h2>
                <p class="mb-0">Marketing Opt-ins</p>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Pending/Recent Requests -->
        <div class="col-md-7">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-bottom d-flex align-items-center">
                    <i class="fa fa-list-alt text-info mr-2"></i>
                    <h5 class="mb-0">Recent Data Portability Requests</h5>
                </div>
                <div class="card-body">
                    {{#has_requests}}
                    <div class="table-responsive">
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>User</th>
                                    <th>Categories</th>
                                    <th>Date</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                {{#requests}}
                                <tr>
                                    <td>{{user}}</td>
                                    <td><small>{{categories}}</small></td>
                                    <td><small>{{date}}</small></td>
                                    <td><span class="badge badge-success">{{status}}</span></td>
                                </tr>
                                {{/requests}}
                            </tbody>
                        </table>
                    </div>
                    {{/has_requests}}
                    {{^has_requests}}
                    <p class="text-muted text-center py-4">No requests found.</p>
                    {{/has_requests}}
                </div>
            </div>
        </div>

        <!-- Retention Policy Alerts -->
        <div class="col-md-5">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-bottom d-flex align-items-center">
                    <i class="fa fa-exclamation-triangle text-danger mr-2"></i>
                    <h5 class="mb-0">Retention Policy Alerts</h5>
                </div>
                <div class="card-body">
                    <p class="small text-muted">Users inactive for more than 180 days (PDPA potential cleanup).</p>
                    {{#has_alerts}}
                    <ul class="list-group list-group-flush">
                        {{#alerts}}
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <div>
                                <strong>{{user}}</strong><br>
                                <small class="text-muted">Last access: {{lastaccess}}</small>
                            </div>
                            <span class="badge badge-danger badge-pill">{{days}} days</span>
                        </li>
                        {{/alerts}}
                    </ul>
                    {{/has_alerts}}
                    {{^has_alerts}}
                    <p class="text-muted text-center py-4">No retention alerts at this time.</p>
                    {{/has_alerts}}
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.pdpa-dashboard .card {
    border-radius: 10px;
}
.pdpa-dashboard h2 {
    font-weight: 700;
}
</style>
