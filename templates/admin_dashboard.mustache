<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    (function() {
        // Consent Distribution Pie (Sharing, Analytics, Marketing)
        const consentCtx = document.getElementById('consentPieChart').getContext('2d');
        new Chart(consentCtx, {
            type: 'pie',
            data: {
                labels: ['Sharing Consent', 'Analytics Consent', 'Marketing Consent'],
                datasets: [{
                    data: [{{raw_consent_sharing}}, {{raw_consent_analytics}}, {{raw_consent_marketing}}],
                    backgroundColor: ['#1e7b5c', '#3b82f6', '#e9a23b'],
                    borderWidth: 0,
                    hoverOffset: 8,
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { position: 'bottom', labels: { font: { size: 11, family: 'Inter' }, usePointStyle: true, boxWidth: 8 } },
                    tooltip: { backgroundColor: '#1f2f3e', titleFont: { size: 12 }, bodyFont: { size: 11 } }
                }
            }
        });

        // Retention Doughnut (Active vs Stale)
        const retentionCtx = document.getElementById('retentionDoughnutChart').getContext('2d');
        new Chart(retentionCtx, {
            type: 'doughnut',
            data: {
                labels: ['Active Users', 'Stale Users'],
                datasets: [{
                    data: [{{raw_active_users}}, {{raw_stale_users}}],
                    backgroundColor: ['#1e7b5c', '#dc6b5e'],
                    borderWidth: 0,
                    cutout: '65%',
                    borderRadius: 6,
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom', labels: { font: { size: 11 }, usePointStyle: true } }
                }
            }
        });

        // Bar chart: Popular Data Requests (Access, Rectification, Erasure, Portability)
        const reqCtx = document.getElementById('requestsBarChart').getContext('2d');
        new Chart(reqCtx, {
            type: 'bar',
            data: {
                labels: {{{raw_request_labels}}},
                datasets: [{
                    label: 'Requests count',
                    data: {{{raw_request_counts}}},
                    backgroundColor: '#548f7b',
                    borderRadius: 10,
                    barPercentage: 0.65,
                    categoryPercentage: 0.8,
                    hoverBackgroundColor: '#266b52'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { position: 'top', labels: { font: { size: 11, weight: '500' } } },
                    tooltip: { backgroundColor: '#2c3e44' }
                },
                scales: {
                    y: { grid: { color: '#e9edf2' }, ticks: { stepSize: 30, font: { size: 10 } }, title: { display: true, text: 'Number of Requests', font: { size: 10 } } },
                    x: { ticks: { font: { size: 10, weight: '500' }, maxRotation: 25 }, grid: { display: false } }
                }
            }
        });
    })();
</script>

